# Frontend (Vite — must be prefixed with VITE_)
# Local:
VITE_API_URL=http://localhost:3005
# Production (Vercel build-time): set to your Railway public API origin, e.g.
# VITE_API_URL=https://your-api.up.railway.app
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Backend / scripts (from Supabase → Connect → App Frameworks)
# Production (Railway): set these on the Railway service
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Supabase Auth redirect URLs (Dashboard → Authentication → URL Configuration):
# Local:
# - Site URL: http://localhost:5173
# - Redirect URLs: http://localhost:5173, http://localhost:5173/
# Production (Vercel):
# - Site URL: https://your-app.vercel.app
# - Redirect URLs: https://your-app.vercel.app, https://your-app.vercel.app/
#   Required for sign-up email confirmation and password recovery links

# Legacy aliases (still supported)
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Backend
PORT=3005
# Optional bind address (defaults to 0.0.0.0 for Railway)
# HOST=0.0.0.0
# Local frontend origin:
CORS_ORIGIN=http://localhost:5173
# Production (Railway): set to your Vercel origin, e.g.
# CORS_ORIGIN=https://your-app.vercel.app

# Optional: local dev without signing in (DO NOT set on Railway production)
DEV_USER_ID=dev-user-001

# Optional: direct Postgres access (SQL editor / migrations only)
# DB_PASSWORD=

# See docs/deploy.md for Railway + Vercel first-deploy order.
